---
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByOrder } from "@/utils/query";

interface Props { isHomepage?: boolean; }
const { isHomepage = false } = Astro.props;
---

<section id="about" class="py-16 lg:py-[70px]">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <h2 class="font-mont font-bold text-center text-[28px] sm:text-[36px] lg:text-[40px] leading-[1.05] text-black">
      We Do The Work So You Don't Have To
    </h2>

    <div class="mt-12 grid gap-12 lg:gap-16 lg:grid-cols-3">

      <!-- Col 1: Founder story + socials -->
      <div>
        <h3 class="font-mont font-bold text-[25px] leading-[37.5px] text-[#333]">
          Founded By Teens on a<br/>Mission for Success...
        </h3>
        <p class="mt-4 font-sans text-[18px] leading-[27px] text-black">
          Pronto Junk Removal, founded in 2022{isHomepage ? " and based in Woodbridge, NJ," : ","} is a business operated by 18 year old teenager Anthony Gonzalez and his friends. We are committed to fast and efficient disposal and making space reclamation a hassle-free experience.
        </p>

        <div class="mt-8 overflow-hidden">
          <img src="/assets/founder.png" alt="Founder" class="w-full h-auto block"/>
        </div>

        <h3 class="mt-10 font-mont font-bold text-[25px] leading-[37.5px] text-[#333]">Our Socials</h3>
        <div class="mt-4 flex gap-4">
          <a href="#" aria-label="Instagram"
            class="w-12 h-12 rounded-full bg-black grid place-items-center text-primary hover:scale-105 transition">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" aria-label="Facebook"
            class="w-12 h-12 rounded-full bg-black grid place-items-center text-primary hover:scale-105 transition">
            <svg width="14" height="22" viewBox="0 0 14 24" fill="currentColor">
              <path d="M9 24v-9h3l1-4H9V8.5C9 7.5 9.5 7 10.5 7H13V3h-3C7 3 5 5 5 8v3H2v4h3v9z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Team photos -->
      <div>
        <h3 class="font-mont font-bold text-[25px] leading-[37.5px] text-[#333]">Meet The Junk Crew</h3>
        <div class="mt-4 overflow-hidden">
          <img src="/assets/team1.jpg" alt="The Junk Crew" class="w-full h-auto block"/>
        </div>
        <div class="mt-6 overflow-hidden">
          <img src="/assets/team2.jpg" alt="The Junk Crew on the job" class="w-full h-auto block"/>
        </div>
      </div>

      <!-- Col 3: Services accordion -->
      <ContentRenderer
        query={query("services").orderBy(sortByOrder())}
        variant="ServicesVariant"
        title="What We Do"
      />

    </div>
  </div>
</section>
