---
import DefaultImg from "@/assets/hero.jpg";

export interface Props {
  title: string;
  url?: string;
  description?: string;
  featuredImage?: { src: any; alt?: string } | null;
  image?: { src: string; alt: string };
}

const { title, url, description, featuredImage, image } = Astro.props;

function imgSrc(raw: any): string | undefined {
  if (!raw) return undefined;
  if (typeof raw === "string") return raw;
  if (raw.src) return typeof raw.src === "string" ? raw.src : (raw.src?.src ?? undefined);
  return undefined;
}

const resolvedSrc = imgSrc(featuredImage) ?? imgSrc(image) ?? (DefaultImg as any).src ?? DefaultImg;
const resolvedAlt = (featuredImage as any)?.alt ?? (image as any)?.alt ?? title;
---

<div class="bg-white overflow-hidden shadow-sm border border-black/8 flex flex-col h-full hover:-translate-y-1 hover:shadow-md transition-all duration-300">
  <div class="h-[220px] overflow-hidden shrink-0">
    <img
      src={resolvedSrc}
      alt={resolvedAlt}
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>

  <div class="p-6 flex-1 flex flex-col">
    <h3 class="font-mont font-bold text-[20px] leading-snug text-black">{title}</h3>

    {description && (
      <p class="mt-3 font-sans text-[15px] leading-[1.6] text-[#555] flex-1">{description}</p>
    )}

    {url && (
      <a href={url} class="feature-card-link inline-block mt-4 text-[13px] font-sans text-black self-start">
        Learn More →
      </a>
    )}
  </div>
</div>

<style>
  .feature-card-link {
    position: relative;
  }
  .feature-card-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 2px;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .feature-card-link:hover::after {
    transform: scaleX(1);
  }
</style>
