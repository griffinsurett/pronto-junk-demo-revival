---
import { siteData, ctaData } from "@/content/siteData";
import { animationProps } from "@/integrations/scroll-animations";
---

<section id="contact" class="relative" style="background: linear-gradient(180deg,#FFA800 0%, #000 100%);">
  <div class="max-w-[1200px] mx-auto px-6 py-14 lg:py-20 text-center">
    <h2 {...animationProps("fade-in-up", { once: true })} class="font-mont font-bold text-[24px] lg:text-[25px] text-black">Want Junk Removed?</h2>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a {...animationProps("pop-in", { once: true, delay: 100 })} href={ctaData.link} class="inline-flex items-center justify-center px-10 h-[50px] rounded-sm font-sans font-medium text-[20px] btn-yellow">
        {ctaData.text}
      </a>
      <a {...animationProps("pop-in", { once: true, delay: 200 })} href={siteData.phoneHref} class="inline-flex items-center justify-center gap-3 px-10 h-[50px] rounded-sm font-sans font-medium text-[20px] btn-black">
        <svg width="14" height="14" viewBox="0 0 13 13" fill="currentColor">
          <path d="M12.528.625 9.887.016a.751.751 0 0 0-.698.352L7.97 3.212a.74.74 0 0 0 .176.711l1.538 1.26a11.27 11.27 0 0 1-4.5 4.499l-1.258-1.539a.745.745 0 0 0-.711-.175L.371 9.187a.747.747 0 0 0-.356.7l.61 2.641A.75.75 0 0 0 1.219 13C7.722 13 13 7.732 13 1.219A.75.75 0 0 0 12.528.625z"/>
        </svg>
        Call Us
      </a>
    </div>
  </div>
</section>
