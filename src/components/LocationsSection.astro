---
import { roots, children } from "@/utils/query/snippets";
import { find } from "@/utils/query";
import { animationProps } from "@/integrations/scroll-animations";
import { ctaData } from "@/content/siteData";

const locationEntry = await find("contact-us", "location");
const locationData = locationEntry?.data;
const locationText = (locationData as any)?.description || "Woodbridge Township, NJ 07095";
const locationTitle = locationData?.title || "Woodbridge Township, NJ";
const locationUrl = (locationData as any)?.url || "https://www.google.com/maps/search/?api=1&query=Woodbridge%20Township%2C%20NJ%2007095";
const mapEmbedUrl = (locationData as any)?.mapEmbedUrl || "https://maps.google.com/maps?q=40.5576,-74.2846&z=13&output=embed";

const counties = await roots("locations").all();

const countyRows = await Promise.all(
  counties.map(async (county) => {
    const towns = await children("locations", county.id).all();
    return { county, towns };
  })
);
---

<section id="locations" class="py-16 lg:py-[70px]">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
    <h2 {...animationProps("fade-in-up", { once: true })} class="font-rob font-bold text-center text-[28px] lg:text-[32px] leading-[1.1] text-[#333]">
      We are Located In {locationTitle}
    </h2>

    <div class="mt-10 flex flex-col lg:flex-row gap-10 lg:items-start">

      <!-- County accordions (scrolls) -->
      <div {...animationProps("fade-in-left", { once: true, delay: 100 })} class="space-y-2 lg:flex-1">
        <h3 class="font-mont font-bold text-[25px] leading-[37.5px] text-[#333]">Our Service Locations</h3>
        <div class="mt-4 space-y-1">
          {countyRows.map(({ county, towns }) => (
            <details>
              <summary class="flex items-center gap-3 py-1 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <span class="accordion-bullet chev shrink-0">
                  <svg width="9" height="5" viewBox="0 0 9 5" fill="#000">
                    <path d="M8.126 4.941H.587C.065 4.941-.196 4.31.173 3.941L3.942.172a.585.585 0 0 1 .829 0l3.769 3.769c.369.369.108 1-.414 1z"/>
                  </svg>
                </span>
                <span class="font-rob font-bold text-[16px] text-black">{county.data.title}</span>
              </summary>
              {towns.length > 0 && (
                <div class="pl-[40px] pb-3 pt-1">
                  <ul class="grid grid-cols-2 gap-x-4 gap-y-1">
                    {towns.map((town) => (
                      <li class="font-sans text-[15px] leading-[1.6] text-[#555]">{town.data.title}</li>
                    ))}
                  </ul>
                </div>
              )}
            </details>
          ))}
        </div>
      </div>

      <!-- Map (sticky) -->
      <div {...animationProps("fade-in-right", { once: true, delay: 150 })} class="sticky-section lg:w-[45%] shrink-0 w-full h-[300px] lg:h-[420px] rounded-sm overflow-hidden border border-black/10 shadow-sm">
        <iframe
          src={mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Map of ${locationText}`}
        ></iframe>
      </div>
    </div>

    <!-- Outside of this area? -->
    <div {...animationProps("fade-in-up", { once: true })} class="mt-16 text-center">
      <h3 class="font-mont font-bold text-[25px] leading-[37.5px] text-[#333]">Outside Of This Area?</h3>
      <p class="mt-3 font-sans text-[18px] leading-[27px] max-w-3xl mx-auto">
        We still would love to work with you, just contact us with your location, and details of the job you want and we will be happy to help you!
      </p>
      <a href={ctaData.link}
        class="btn-yellow mt-6 inline-flex items-center justify-center px-10 h-[50px] rounded-sm font-sans font-medium text-[20px]">
        {ctaData.text}
      </a>
    </div>
  </div>
</section>
