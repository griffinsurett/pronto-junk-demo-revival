---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FrontPageHero from "@/layouts/FrontPageHero.astro";
import MainPageSections from "@/layouts/MainPageSections.astro";
import { siteData, ctaData } from "@/content/siteData";

const { entry } = Astro.props;
const locationName = entry?.data?.title ?? "Your Area";
---

<BaseLayout
  title={`Junk Removal in ${locationName}`}
  description={`Fast, reliable junk removal serving ${locationName}, NJ. Call Pronto Junk Removal for same-day service.`}
>
  <main class="flex-1">
    <FrontPageHero
      eyebrow={`Serving ${locationName}`}
      title={siteData.title}
      primaryCTA={ctaData}
    />
    <MainPageSections />
  </main>
</BaseLayout>
