---
// src/layouts/HeadTags.astro
/**
 * Head Tags Component
 * 
 * Placeholder for additional head-level tags and scripts.
 * Can include:
 * - Analytics scripts (Google Analytics, Plausible, etc.)
 * - Font preloads
 * - External script tags
 * - Additional meta tags
 * 
 * Separated into its own component for easier maintenance
 * and conditional loading of third-party scripts.
 */
import IntHeadScripts from "@/integrations/IntHeadScripts.astro";
---
<IntHeadScripts />
<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700;900&family=Raleway:wght@400;500&family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet" />
