---
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortBy } from "@/utils/query";
import { siteData } from "@/content/siteData";
import { filterByMenu } from "@/utils/menuQueries";

const mainMenuQuery = query("menu-items")
  .where(filterByMenu("main-menu"))
  .orderBy(sortBy("order", "asc"));
---

<header class="sticky top-0 z-50 bg-white" style="box-shadow:0 0 10px 0 rgba(0,0,0,0.5);">
  <div class="max-w-[1440px] mx-auto px-4 xl:px-[54px] h-[88px] xl:h-[107px] flex items-center justify-between">

    <ContentRenderer
      query={mainMenuQuery}
      variant="MenuVariant"
      mode="hamburger-only"
      className="xl:hidden"
      showHeadingSection={false}
    />

    <div class="flex items-center gap-8 xl:gap-12">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img src="/assets/logo.png" alt={siteData.title} class="w-[68px] h-[68px] xl:w-[88px] xl:h-[88px] object-contain"/>
      </a>

      <!-- Desktop nav -->
      <ContentRenderer
        query={mainMenuQuery}
        variant="MenuVariant"
        mode="flat-only"
        className="pronto-header-menu hidden xl:block"
        showHeadingSection={false}
      />
    </div>

    <!-- Desktop phone CTA -->
    <a href={siteData.phoneHref}
      class="hidden xl:inline-flex items-center gap-3 px-6 h-[65px] rounded-md font-sans font-medium text-[18px] btn-yellow"
      aria-label={`Call us at ${siteData.phone}`}
    >
      <svg width="18" height="18" viewBox="0 0 13 13" fill="currentColor">
        <path d="M12.528.625 9.887.016a.751.751 0 0 0-.698.352L7.97 3.212a.74.74 0 0 0 .176.711l1.538 1.26a11.27 11.27 0 0 1-4.5 4.499l-1.258-1.539a.745.745 0 0 0-.711-.175L.371 9.187a.747.747 0 0 0-.356.7l.61 2.641A.75.75 0 0 0 1.219 13C7.722 13 13 7.732 13 1.219A.75.75 0 0 0 12.528.625z"/>
      </svg>
      <span>{siteData.phone}</span>
    </a>

    <!-- Mobile phone icon -->
    <a href={siteData.phoneHref}
      class="xl:hidden w-12 h-12 rounded-full bg-primary grid place-items-center"
      aria-label={`Call us at ${siteData.phone}`}
    >
      <svg width="22" height="22" viewBox="0 0 13 13" fill="#000">
        <path d="M12.528.625 9.887.016a.751.751 0 0 0-.698.352L7.97 3.212a.74.74 0 0 0 .176.711l1.538 1.26a11.27 11.27 0 0 1-4.5 4.499l-1.258-1.539a.745.745 0 0 0-.711-.175L.371 9.187a.747.747 0 0 0-.356.7l.61 2.641A.75.75 0 0 0 1.219 13C7.722 13 13 7.732 13 1.219A.75.75 0 0 0 12.528.625z"/>
      </svg>
    </a>

  </div>
</header>
