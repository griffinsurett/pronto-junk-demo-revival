---
// src/layouts/SecondaryHero.astro
/**
 * Secondary Hero Layout
 *
 * Full-width hero with optimized background media support.
 * Uses BackgroundMedia component for responsive image optimization.
 *
 * Features:
 * - Responsive background images (mobile/tablet/desktop)
 * - Automatic LCP optimization with aboveTheFold
 * - Gradient overlay for text readability
 * - Optional metadata display (date, author, reading time)
 */

import { getAuthorName } from "@/layouts/collections/helpers/layoutHelpers";
import BackgroundMedia from "@/components/BackgroundMedia.astro";
import backgroundSvg from "@/assets/hero.jpg";

export interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  image?: any; // Astro image asset or public path
  publishDate?: Date | string;
  author?: string | { collection: string; id: string };
  readingTime?: number;
  className?: string;
  minHeight?: string;
}

const {
  title,
  eyebrow,
  description,
  image,
  publishDate,
  author,
  readingTime,
  className = "",
  minHeight = "60vh",
} = Astro.props;

// Prepare optimized background media
const backgroundMedia = {
  image: {
    src: image || backgroundSvg,
    imageClass: "bg-cover bg-center",
    aboveTheFold: true, // Automatic LCP optimization
  },
  overlayClass: "bg-gradient-to-b from-black/40 via-black/50 to-black/70",
};
---

<section class={`relative ${className}`}>
  <div
    class="relative flex items-center justify-center overflow-hidden"
    style={`min-height: ${minHeight}`}
  >
    {/* Optimized background with overlay */}
    <BackgroundMedia backgroundMedia={backgroundMedia} />

    {/* Hero content */}
    <div class="relative container mx-auto px-4 py-16 md:py-24 z-10">
      <div class="max-w-4xl mx-auto text-center text-bg">
        <nav aria-label="Breadcrumb" class="flex items-center justify-center gap-2 mb-6 text-sm md:text-base text-bg/80">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <svg class="w-3 h-3 text-bg/50 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          {eyebrow && eyebrow !== title ? (
            <>
              <span class="text-bg/80">{eyebrow}</span>
              <svg class="w-3 h-3 text-bg/50 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </>
          ) : null}
          <span class="text-white font-medium" aria-current="page">{title}</span>
        </nav>

        <h1 class="font-rob font-black uppercase text-[48px] md:text-[64px] lg:text-[80px] leading-tight mb-6 drop-shadow-lg">
          {title}
        </h1>

        {
          description && (
            <p class="mt-4 font-mont font-bold text-[18px] lg:text-[20px] leading-relaxed opacity-95 drop-shadow-md">
              {description}
            </p>
          )
        }

        {/* Metadata row with icons */}
        {
          (publishDate || author || readingTime) && (
            <div class="flex flex-wrap justify-center gap-4 md:gap-6 text-sm md:text-base text-bg/90">
              {publishDate && (
                <time
                  datetime={new Date(publishDate).toISOString()}
                  class="flex items-center gap-2"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                    />
                  </svg>
                  {new Date(publishDate).toLocaleDateString()}
                </time>
              )}

              {author && (
                <span class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    />
                  </svg>
                  By {getAuthorName(author)}
                </span>
              )}

              {readingTime && (
                <span class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                  {readingTime} min read
                </span>
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>

  {/* Optional slot for additional content below hero */}
  <slot />
</section>

