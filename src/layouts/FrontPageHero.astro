---
// src/layouts/FrontPageHero.astro
/**
 * Front Page Hero Layout
 *
 * Full-width hero section with optimized background media for homepage.
 *
 * Features:
 * - Responsive background images with LCP optimization
 * - Optional video background with poster image
 * - Large centered text with gradient overlay
 * - Primary and secondary CTAs
 * - Configurable minimum height (default 95vh)
 * - Supports both static images and video backgrounds
 *
 * This is a layout component for landing pages.
 * Use directly in your homepage or marketing pages.
 */

import BackgroundMedia from "@/components/BackgroundMedia.astro";
import { ctaData } from "@/content/siteData";
import DefaultImg from "@/assets/hero.jpg";
import { animationProps } from "@/integrations/scroll-animations";

export interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  image?: any;
  video?: {
    src: string;
    autoPlay?: boolean;
    muted?: boolean;
    loop?: boolean;
    playsInline?: boolean;
    controls?: boolean;
    preload?: string;
  };
  primaryCTA?: {
    text: string;
    link: string;
  };
  secondaryCTA?: {
    text: string;
    link: string;
  };
  className?: string;
  id?: string;
  minHeight?: string;
}

const {
  title = "Welcome",
  eyebrow,
  description,
  image,
  video,
  primaryCTA = {
    text: ctaData.text,
    link: ctaData.link,
  },
  secondaryCTA,
  className = "",
  id = "hero",
  minHeight = "90vh",
} = Astro.props;

const backgroundMedia = {
  image: {
    src: image || DefaultImg,
    aboveTheFold: true,
  },
  video: video
    ? {
        src: video.src,
        autoPlay: video.autoPlay ?? true,
        muted: video.muted ?? true,
        loop: video.loop ?? true,
        playsInline: video.playsInline ?? true,
        controls: video.controls ?? false,
        preload: video.preload ?? "metadata",
        videoClass: "object-cover",
      }
    : undefined,
  overlayClass: "bg-black/60",
};
---

<section id={id} class={`relative overflow-hidden text-white flex items-center justify-center ${className}`} style={`min-height:${minHeight}`}>
  <BackgroundMedia backgroundMedia={backgroundMedia} />

  <div class="relative w-full max-w-[1440px] mx-auto px-6 lg:px-12 text-center z-10">
    {eyebrow && (
      <p {...animationProps("fade-in", { once: true, delay: 0 })} class="font-mont font-bold uppercase tracking-wide text-[18px] lg:text-[20px]">
        {eyebrow}
      </p>
    )}
    <h1 {...animationProps("fade-in-up", { once: true, delay: eyebrow ? 100 : 0 })} class:list={["font-rob font-black leading-[60px] lg:leading-[105px] text-[60px] lg:text-[105px] uppercase", eyebrow ? "mt-6" : ""]}>
      {title}
    </h1>
    {description && (
      <p {...animationProps("fade-in-up", { once: true, delay: 200 })} class="mt-6 font-sans text-[18px] lg:text-[20px] leading-relaxed max-w-2xl mx-auto opacity-90">
        {description}
      </p>
    )}
    <div {...animationProps("fade-in-up", { once: true, delay: 300 })} class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      {primaryCTA && (
        <a href={primaryCTA.link} class="inline-flex items-center justify-center w-[300px] h-20 rounded-md font-mont font-bold text-[25px] btn-yellow mx-auto sm:mx-0">
          {primaryCTA.text}
        </a>
      )}
      {secondaryCTA && (
        <a href={secondaryCTA.link} class="inline-flex items-center justify-center px-10 h-20 rounded-md font-mont font-bold text-[20px] btn-black">
          {secondaryCTA.text}
        </a>
      )}
    </div>
  </div>

  <slot />
</section>
