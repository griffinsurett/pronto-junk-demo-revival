---
import { animationProps } from "@/integrations/scroll-animations";

interface Props {
  heading: string;
  body: string;
  image?: ImageMetadata | string;
  index?: number;
}

const { heading, body, image, index = 0 } = Astro.props;
const isEven = index % 2 === 0;

function imgSrc(raw: any): string | undefined {
  if (!raw) return undefined;
  if (typeof raw === "string") return raw;
  return raw.src ?? undefined;
}

const src = imgSrc(image);
---

<div class:list={["flex flex-col gap-10 items-center", isEven ? "lg:flex-row" : "lg:flex-row-reverse"]}>

  {/* ── Text ── */}
  <div {...animationProps(isEven ? "fade-in-right" : "fade-in-left", { once: true })} class="flex-1 min-w-0">
    <h2 class="font-mont font-bold text-[26px] lg:text-[32px] leading-tight text-[#111] mb-4">{heading}</h2>
    <p class="font-sans text-[17px] leading-[1.75] text-[#444]">{body}</p>
    <slot />
  </div>

  {/* ── Image ── */}
  <div {...animationProps(isEven ? "fade-in-left" : "fade-in-right", { once: true })} class="flex-1 min-w-0 w-full">
    {src ? (
      <img
        src={src}
        alt={heading}
        class="w-full aspect-[4/3] object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-full aspect-[4/3] bg-neutral-100 flex items-center justify-center">
        <span class="text-neutral-400 font-sans text-sm">Photo coming soon</span>
      </div>
    )}
  </div>

</div>
